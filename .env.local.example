# Copy this file to `.env.local` and fill in the real values.
# `.env.local` is gitignored; never commit secrets.

# Supabase — get these from the Supabase dashboard:
# Project Settings → API → "Project URL" and "anon public" key.
NEXT_PUBLIC_SUPABASE_URL=https://evdwlibjbxqfasvnxfxd.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Dev-only: when "true", surfaces a "Seed Valencia guide" button on /home
# that drops a public guide named justin-valencia (or whatever-valencia)
# under your account. Leave blank in production.
ALLOW_DEV_SEED=true

# Canonical site URL — used to build magic-link callback URLs and the
# copy-to-clipboard share link on the author's guide page. In Vercel
# production / preview, set this to the deployment URL so an attacker
# can't spoof Host: evil.com and poison shared links.
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Mapbox public token. Renders the recipient map. Public tokens are
# meant to live in the client bundle — security comes from URL-referrer
# restrictions configured in the Mapbox dashboard for the production
# hostname. Get it from: https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=
